FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-devel

# System tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    screen vim grep htop curl net-tools procps git \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies — shared across all backends
RUN pip install --no-cache-dir \
    pandas tabulate tiktoken tqdm xlsxwriter tenacity datasets openai azure-ai-inference \
    pyyaml pytest huggingface_hub[cli] wandb \
    && ln -sf "$(which python3)" /usr/local/bin/python

# Convenience script to update code mid-session without restarting
RUN cat <<'SCRIPT' > /usr/local/bin/mmtu-update && chmod +x /usr/local/bin/mmtu-update
#!/bin/bash
set -e
cd /workspace/MMTU
echo "Pulling latest code..."
git pull
echo "Installing requirements..."
pip install -q -r requirements.txt
echo "Done."
SCRIPT
