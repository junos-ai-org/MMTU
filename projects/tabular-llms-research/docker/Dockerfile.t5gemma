ARG BASE_IMAGE=tabular-llms-base:latest
FROM ${BASE_IMAGE}

# T5Gemma backend: HuggingFace transformers + flash-attn (compiled from source)
RUN pip install --no-cache-dir \
    transformers accelerate sentencepiece protobuf \
    flash-attn --no-build-isolation

# Copy entrypoint (code is cloned from git at runtime, not baked into image)
COPY projects/tabular-llms-research/docker/entrypoint-t5gemma.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT []
CMD ["/entrypoint.sh"]
