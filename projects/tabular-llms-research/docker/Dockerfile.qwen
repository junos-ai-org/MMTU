ARG BASE_IMAGE=tabular-llms-base:latest
FROM ${BASE_IMAGE}

# Qwen2.5 backend: vLLM (brings its own attention kernels, no flash-attn needed)
RUN pip install --no-cache-dir vllm

# Copy entrypoint (code is cloned from git at runtime, not baked into image)
COPY projects/tabular-llms-research/docker/entrypoint-qwen.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT []
CMD ["/entrypoint.sh"]
